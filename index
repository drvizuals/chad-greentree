<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GreenTree × DR&amp;AV — The Flywheel Proposal</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,200;0,9..144,300;0,9..144,500;1,9..144,200;1,9..144,300&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
:root {
  --white:    #FFFFFF;
  --off:      #F7F9F7;
  --cream:    #F2F5F0;
  --border:   #E4EBE4;
  --border2:  #D0DECE;
  --green:    #1A5C28;
  --green2:   #236B33;
  --mid:      #2E8A42;
  --sage:     #5AAF72;
  --mist:     #B8D9C1;
  --pale:     #EBF4EE;
  --pale2:    #DCEEE2;
  --ink:      #0F1A11;
  --dark:     #1C2E1E;
  --body:     #4A5E4D;
  --muted:    #7A917D;
  --gold:     #B8863A;
  --gold-bg:  #FBF5EB;
  --gold-bd:  #E8D0A0;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Plus Jakarta Sans', sans-serif;
  background: var(--white);
  color: var(--ink);
  overflow-x: hidden;
}

/* ── NAV ───────────────────────────────────────── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  background: rgba(255,255,255,0.94);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  display: flex; justify-content: space-between; align-items: center;
  padding: 1rem 3rem;
}
.nav-brand {
  font-family: 'Fraunces', serif;
  font-weight: 300; font-size: 1rem;
  color: var(--green); letter-spacing: .02em;
}
.nav-brand em { font-style: italic; color: var(--sage); }
.nav-links { display: flex; gap: 2rem; list-style: none; }
.nav-links a {
  font-size: .73rem; font-weight: 500;
  letter-spacing: .1em; text-transform: uppercase;
  color: var(--muted); text-decoration: none;
  transition: color .25s;
}
.nav-links a:hover { color: var(--green); }
.nav-btn {
  font-size: .72rem; font-weight: 600;
  letter-spacing: .1em; text-transform: uppercase;
  padding: .6rem 1.6rem; border-radius: 100px;
  background: var(--green); color: #fff;
  text-decoration: none; transition: background .25s;
}
.nav-btn:hover { background: var(--green2); }

/* ── REVEAL ────────────────────────────────────── */
.reveal { opacity: 0; transform: translateY(22px); transition: opacity .65s ease, transform .65s ease; }
.reveal.on { opacity: 1; transform: none; }

/* ── HERO ──────────────────────────────────────── */
.hero {
  min-height: 100vh;
  background: var(--ink);
  display: flex; flex-direction: column; justify-content: flex-end;
  padding: 10rem 3rem 5.5rem;
  position: relative; overflow: hidden;
}
.hero-bg-circle {
  position: absolute; border-radius: 50%; pointer-events: none;
}
.hbc1 {
  width: 800px; height: 800px;
  top: -200px; right: -150px;
  background: radial-gradient(circle, rgba(26,92,40,.35) 0%, transparent 70%);
  animation: breathe 12s ease-in-out infinite;
}
.hbc2 {
  width: 500px; height: 500px;
  bottom: -100px; left: -100px;
  background: radial-gradient(circle, rgba(26,92,40,.15) 0%, transparent 70%);
  animation: breathe 16s ease-in-out infinite reverse;
}
@keyframes breathe { 0%,100%{transform:scale(1);} 50%{transform:scale(1.18);} }

.hero-label {
  display: flex; align-items: center; gap: .75rem;
  font-size: .68rem; font-weight: 500;
  letter-spacing: .18em; text-transform: uppercase;
  color: var(--sage); margin-bottom: 2rem;
  opacity: 0; animation: fadeUp .8s .3s forwards;
}
.hero-label-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--sage);
  animation: pulse-dot 2.5s ease-in-out infinite;
}
@keyframes pulse-dot { 0%,100%{opacity:1;} 50%{opacity:.2;} }

.hero-h {
  font-family: 'Fraunces', serif;
  font-size: clamp(3.5rem, 7.5vw, 8.5rem);
  font-weight: 200; line-height: .92;
  letter-spacing: -.02em; color: #fff;
  opacity: 0; animation: fadeUp 1s .5s forwards;
}
.hero-h em { font-style: italic; color: var(--sage); }

.hero-sub {
  margin-top: 2.5rem;
  font-size: 1.02rem; font-weight: 300;
  line-height: 1.8; color: rgba(255,255,255,.45);
  max-width: 460px;
  opacity: 0; animation: fadeUp .9s .72s forwards;
}

.hero-chips {
  display: flex; flex-wrap: wrap; gap: .75rem;
  margin-top: 3.5rem;
  opacity: 0; animation: fadeUp .9s .9s forwards;
}
.chip {
  display: flex; align-items: center; gap: .6rem;
  padding: .55rem 1.1rem;
  border-radius: 100px;
  border: 1px solid rgba(255,255,255,.1);
  background: rgba(255,255,255,.04);
  font-size: .8rem; font-weight: 400;
  color: rgba(255,255,255,.65);
}
.chip-dot {
  width: 5px; height: 5px; border-radius: 50%;
  background: var(--sage); flex-shrink: 0;
}

.hero-stats {
  display: flex; gap: 3.5rem; flex-wrap: wrap;
  margin-top: 4rem; padding-top: 3rem;
  border-top: 1px solid rgba(255,255,255,.08);
  opacity: 0; animation: fadeUp 1s 1.1s forwards;
}
.hs-n {
  font-family: 'Fraunces', serif;
  font-size: 2.8rem; font-weight: 200;
  color: #fff; line-height: 1;
}
.hs-n em { color: var(--sage); font-style: normal; font-size: 1.7rem; }
.hs-l {
  font-size: .62rem; font-weight: 500;
  letter-spacing: .1em; text-transform: uppercase;
  color: rgba(255,255,255,.28); margin-top: .25rem;
}

@keyframes fadeUp { from{opacity:0;transform:translateY(22px);}to{opacity:1;transform:none;} }

/* ── SECTION PARTS ─────────────────────────────── */
.section { padding: 7rem 3rem; }
.section.off { background: var(--off); }
.section.pale { background: var(--pale); }
.section.white { background: var(--white); }

.eyebrow {
  display: flex; align-items: center; gap: .85rem;
  font-size: .65rem; font-weight: 600;
  letter-spacing: .2em; text-transform: uppercase;
  color: var(--mid); margin-bottom: 1.1rem;
}
.eyebrow::before {
  content: ''; display: block;
  width: 24px; height: 2px;
  background: var(--mid); border-radius: 2px;
}

.sh {
  font-family: 'Fraunces', serif;
  font-size: clamp(2.4rem, 4vw, 4rem);
  font-weight: 200; line-height: 1.05;
  letter-spacing: -.01em; color: var(--ink);
}
.sh em { font-style: italic; color: var(--green); }

/* ── SITUATION ─────────────────────────────────── */
.sit-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 5rem; margin-top: 4rem; align-items: start;
}
.sit-body {
  font-size: 1.02rem; font-weight: 300;
  line-height: 1.85; color: var(--body);
}
.sit-body p + p { margin-top: 1.3rem; }
.sit-body strong { color: var(--ink); font-weight: 600; }

.cards { display: flex; flex-direction: column; gap: .75rem; }
.card-sm {
  padding: 1.3rem 1.5rem;
  border-radius: 10px;
  border: 1.5px solid var(--border);
  background: var(--white);
  display: flex; gap: 1rem; align-items: flex-start;
  transition: border-color .25s, box-shadow .25s;
}
.card-sm:hover { border-color: var(--mist); box-shadow: 0 4px 20px rgba(26,92,40,.07); }
.card-sm.good { border-color: var(--mist); background: var(--pale); }
.card-sm.gap { border-color: var(--gold-bd); background: var(--gold-bg); }
.csm-ico { font-size: 1.2rem; flex-shrink: 0; margin-top: .05rem; }
.csm-label {
  font-size: .6rem; font-weight: 600;
  letter-spacing: .14em; text-transform: uppercase;
  margin-bottom: .3rem;
}
.good .csm-label { color: var(--mid); }
.gap .csm-label { color: var(--gold); }
.csm-text { font-size: .86rem; font-weight: 300; line-height: 1.6; color: var(--body); }
.csm-text strong { color: var(--ink); font-weight: 600; }

/* ── FLYWHEEL ──────────────────────────────────── */
.fw-section { background: var(--green); padding: 7rem 3rem; }
.fw-section .eyebrow { color: var(--mist); }
.fw-section .eyebrow::before { background: var(--mist); }
.fw-section .sh { color: #fff; }
.fw-section .sh em { color: var(--mist); }
.fw-sub {
  font-size: 1rem; font-weight: 300;
  line-height: 1.78; color: rgba(255,255,255,.55);
  max-width: 480px; margin-top: 1rem;
}

.fw-grid {
  display: grid; grid-template-columns: repeat(4,1fr);
  gap: 1px; margin-top: 4rem;
  background: rgba(255,255,255,.1);
  border-radius: 12px; overflow: hidden;
}
.fw-cell {
  background: rgba(255,255,255,.04);
  padding: 2.2rem 1.8rem;
  transition: background .3s;
  cursor: default;
}
.fw-cell:hover { background: rgba(255,255,255,.1); }
.fw-num {
  font-family: 'Fraunces', serif;
  font-size: 2.5rem; font-weight: 200;
  color: rgba(255,255,255,.15); line-height: 1;
  margin-bottom: .8rem;
}
.fw-title {
  font-size: .82rem; font-weight: 600;
  color: var(--mist); margin-bottom: .55rem;
  letter-spacing: .02em;
}
.fw-desc {
  font-size: .82rem; font-weight: 300;
  line-height: 1.65; color: rgba(255,255,255,.45);
}

.fw-arrow {
  display: flex; align-items: center; justify-content: center;
  gap: 1.5rem; margin-top: 2.5rem;
  font-size: .78rem; font-weight: 400;
  color: rgba(255,255,255,.4);
  flex-wrap: wrap;
}
.fw-arrow-step {
  display: flex; align-items: center; gap: .5rem;
  color: rgba(255,255,255,.6);
}
.fw-arrow-step::after {
  content: '→';
  color: var(--sage); font-size: .85rem;
}
.fw-arrow-step:last-child::after { display: none; }

.fw-pull {
  margin-top: 3.5rem;
  padding: 2.2rem 2.5rem;
  background: rgba(255,255,255,.06);
  border-left: 3px solid var(--mist);
  border-radius: 0 8px 8px 0;
}
.fw-pull p {
  font-family: 'Fraunces', serif;
  font-size: 1.3rem; font-style: italic; font-weight: 300;
  line-height: 1.65; color: rgba(255,255,255,.7);
}
.fw-pull p em { color: var(--mist); font-style: normal; font-weight: 500; }

/* ── BUILD ─────────────────────────────────────── */
.build-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 1.5rem; margin-top: 4rem;
}
.build-card {
  border-radius: 12px; overflow: hidden;
  border: 1.5px solid var(--border);
  background: var(--white);
}
.build-card.dark {
  background: var(--ink);
  border-color: transparent;
}
.bc-head {
  padding: 2rem 2rem 1.6rem;
  border-bottom: 1.5px solid var(--border);
}
.build-card.dark .bc-head {
  border-bottom-color: rgba(255,255,255,.07);
}
.bc-tag {
  font-size: .62rem; font-weight: 600;
  letter-spacing: .15em; text-transform: uppercase;
  color: var(--mid); margin-bottom: .5rem;
}
.build-card.dark .bc-tag { color: var(--sage); }
.bc-title {
  font-family: 'Fraunces', serif;
  font-size: 1.6rem; font-weight: 300; color: var(--ink);
}
.build-card.dark .bc-title { color: #fff; }
.bc-body { padding: 1.8rem 2rem; }
.bi {
  display: flex; gap: .85rem; align-items: flex-start;
  padding: .72rem 0; border-bottom: 1px solid var(--border);
}
.build-card.dark .bi { border-bottom-color: rgba(255,255,255,.05); }
.bi:last-child { border-bottom: none; }
.bi-dot {
  width: 18px; height: 18px; border-radius: 50%;
  background: var(--pale2); flex-shrink: 0; margin-top: .14rem;
  display: flex; align-items: center; justify-content: center;
  font-size: .5rem; color: var(--green); font-weight: 700;
}
.build-card.dark .bi-dot { background: rgba(90,175,114,.15); color: var(--sage); }
.bi-t { font-size: .87rem; font-weight: 300; line-height: 1.6; color: var(--body); }
.build-card.dark .bi-t { color: rgba(255,255,255,.5); }
.bi-t strong { color: var(--ink); font-weight: 600; }
.build-card.dark .bi-t strong { color: #fff; }

.tech-banner {
  grid-column: 1 / -1;
  padding: 1.7rem 2rem;
  background: var(--pale);
  border-radius: 10px;
  border: 1.5px solid var(--mist);
  display: flex; gap: 1.2rem; align-items: flex-start;
}
.tb-icon { font-size: 1.3rem; flex-shrink: 0; margin-top: .1rem; }
.tb-text { font-size: .87rem; font-weight: 300; line-height: 1.65; color: var(--body); }
.tb-text strong { color: var(--ink); font-weight: 600; }

/* ── NUMBERS ───────────────────────────────────── */
.num-trio {
  display: grid; grid-template-columns: repeat(3,1fr);
  gap: 1.5rem; margin-top: 4rem;
}
.num-box {
  padding: 2.5rem 2rem;
  border-radius: 12px;
  border: 1.5px solid var(--border);
  background: var(--white);
}
.num-box.accent {
  background: var(--green); border-color: transparent;
}
.nb-val {
  font-family: 'Fraunces', serif;
  font-size: 3.2rem; font-weight: 200;
  color: var(--ink); line-height: 1;
}
.num-box.accent .nb-val { color: #fff; }
.nb-val em { color: var(--green); font-style: normal; font-size: 2rem; }
.num-box.accent .nb-val em { color: var(--mist); }
.nb-lab {
  font-size: .62rem; font-weight: 600;
  letter-spacing: .1em; text-transform: uppercase;
  color: var(--muted); margin-top: .6rem;
}
.num-box.accent .nb-lab { color: rgba(255,255,255,.45); }
.nb-sub { font-size: .78rem; color: var(--muted); margin-top: .25rem; }
.num-box.accent .nb-sub { color: rgba(255,255,255,.35); }

.tbl-title {
  font-family: 'Fraunces', serif;
  font-size: 1.5rem; font-weight: 300;
  color: var(--ink); margin: 3.5rem 0 1rem;
}

table { width: 100%; border-collapse: collapse; font-size: .87rem; }
th {
  text-align: left; padding: .8rem 1.1rem;
  background: var(--green); color: rgba(255,255,255,.7);
  font-size: .62rem; font-weight: 600;
  letter-spacing: .12em; text-transform: uppercase;
}
th:first-child { border-radius: 8px 0 0 0; }
th:last-child { border-radius: 0 8px 0 0; }
td {
  padding: .85rem 1.1rem;
  border-bottom: 1px solid var(--border);
  color: var(--body); font-weight: 300;
}
tr:last-child td { border-bottom: none; }
tr:nth-child(even) td { background: var(--off); }
.tg { color: var(--green); font-weight: 600; }
.to { color: var(--gold); font-weight: 600; }
.total-row td {
  background: var(--pale2) !important;
  color: var(--green); font-weight: 600;
  font-size: .9rem;
}

.truck-grid {
  display: grid; grid-template-columns: repeat(4,1fr);
  gap: 1px; margin-top: 3rem;
  background: var(--border);
  border-radius: 12px; overflow: hidden;
}
.truck-box { padding: 2rem 1.6rem; background: var(--white); }
.truck-box.hot { background: var(--green); }
.tb-scenario {
  font-size: .6rem; font-weight: 600;
  letter-spacing: .1em; text-transform: uppercase;
  color: var(--muted); margin-bottom: .8rem;
}
.truck-box.hot .tb-scenario { color: var(--mist); }
.tb-n {
  font-family: 'Fraunces', serif;
  font-size: 2.6rem; font-weight: 200;
  color: var(--ink); line-height: 1;
}
.truck-box.hot .tb-n { color: #fff; }
.tb-sub { font-size: .75rem; color: var(--muted); margin-top: .3rem; }
.truck-box.hot .tb-sub { color: rgba(255,255,255,.4); }
.tb-rev { font-size: .84rem; color: var(--muted); margin-top: .9rem; }
.tb-rev strong { color: var(--ink); font-weight: 600; }
.truck-box.hot .tb-rev strong { color: var(--mist); }
.truck-fn { font-size: .8rem; font-weight: 300; font-style: italic; color: var(--muted); margin-top: 1.2rem; }

/* ── FUTURE ────────────────────────────────────── */
.future-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 5rem; align-items: center;
}
.future-body {
  font-size: 1.02rem; font-weight: 300;
  line-height: 1.85; color: var(--body);
}
.future-body p + p { margin-top: 1.3rem; }
.future-body strong { color: var(--ink); font-weight: 600; }
.future-card {
  padding: 2.8rem;
  border-radius: 12px;
  background: var(--pale);
  border: 1.5px solid var(--mist);
  position: relative;
}
.future-card::before {
  content: '"';
  font-family: 'Fraunces', serif;
  font-size: 7rem; line-height: 1;
  color: var(--mist); opacity: .5;
  position: absolute; top: -.5rem; left: 1.8rem;
}
.future-card p {
  font-family: 'Fraunces', serif;
  font-size: 1.3rem; font-style: italic; font-weight: 300;
  line-height: 1.7; color: var(--dark);
  position: relative; z-index: 1;
}
.future-card p em { color: var(--green); font-style: normal; font-weight: 500; }

/* ── PRICING ───────────────────────────────────── */
.price-intro {
  max-width: 540px; margin-bottom: 3.5rem;
}
.price-intro p {
  font-size: 1rem; font-weight: 300;
  line-height: 1.8; color: var(--body); margin-top: 1rem;
}

/* WEBSITE OPTIMIZATION BANNER */
.web-opt {
  padding: 2rem 2.2rem;
  border-radius: 12px;
  background: var(--gold-bg);
  border: 1.5px solid var(--gold-bd);
  display: flex; gap: 2rem; align-items: center;
  margin-bottom: 2.5rem;
  flex-wrap: wrap;
}
.wo-left { flex: 1; min-width: 260px; }
.wo-tag {
  font-size: .6rem; font-weight: 700;
  letter-spacing: .18em; text-transform: uppercase;
  color: var(--gold); margin-bottom: .4rem;
}
.wo-title {
  font-family: 'Fraunces', serif;
  font-size: 1.4rem; font-weight: 300; color: var(--ink);
  margin-bottom: .6rem;
}
.wo-desc {
  font-size: .86rem; font-weight: 300;
  line-height: 1.65; color: var(--body);
}
.wo-desc strong { color: var(--ink); font-weight: 600; }
.wo-right { text-align: center; flex-shrink: 0; }
.wo-price {
  font-family: 'Fraunces', serif;
  font-size: 2.8rem; font-weight: 200; color: var(--gold);
  line-height: 1;
}
.wo-price em { font-style: normal; font-size: 1.2rem; color: var(--gold); }
.wo-once {
  font-size: .7rem; font-weight: 600;
  letter-spacing: .1em; text-transform: uppercase;
  color: var(--gold); margin-top: .3rem;
  opacity: .7;
}
.wo-includes {
  display: flex; flex-wrap: wrap; gap: .5rem; margin-top: 1rem;
}
.wo-tag-item {
  font-size: .73rem; font-weight: 400;
  padding: .3rem .8rem; border-radius: 100px;
  background: rgba(184,134,58,.1);
  border: 1px solid var(--gold-bd);
  color: var(--gold);
}

.price-cards {
  display: grid; grid-template-columns: 1fr 1.35fr 1fr;
  gap: 1.5rem;
}
.pc {
  border-radius: 14px; overflow: hidden;
  border: 1.5px solid var(--border);
  background: var(--white);
  display: flex; flex-direction: column;
}
.pc.star {
  border-color: var(--green);
  box-shadow: 0 8px 40px rgba(26,92,40,.12);
}
.pc-top {
  padding: 2rem 2rem 1.6rem;
  border-bottom: 1.5px solid var(--border);
}
.pc.star .pc-top {
  background: var(--green); border-bottom-color: transparent;
}
.pc-badge {
  display: inline-block;
  font-size: .6rem; font-weight: 700;
  letter-spacing: .14em; text-transform: uppercase;
  background: var(--sage); color: #fff;
  padding: .28rem .9rem; border-radius: 100px;
  margin-bottom: .8rem;
}
.pc-tag {
  font-size: .62rem; font-weight: 600;
  letter-spacing: .15em; text-transform: uppercase;
  color: var(--muted); margin-bottom: .6rem;
}
.pc.star .pc-tag { color: rgba(255,255,255,.5); }
.pc-name {
  font-family: 'Fraunces', serif;
  font-size: 1.4rem; font-weight: 300; color: var(--ink);
  margin-bottom: 1.4rem; line-height: 1.2;
}
.pc.star .pc-name { color: #fff; font-size: 1.6rem; }
.pc-amt {
  font-family: 'Fraunces', serif;
  font-size: 3rem; font-weight: 200;
  color: var(--ink); line-height: 1;
}
.pc.star .pc-amt { color: #fff; font-size: 3.8rem; }
.pc-amt em { font-style: normal; font-size: 1.2rem; color: var(--muted); }
.pc.star .pc-amt em { color: rgba(255,255,255,.45); }
.pc-setup {
  font-size: .75rem; color: var(--muted); margin-top: .35rem;
}
.pc.star .pc-setup { color: rgba(255,255,255,.35); }

.pc-body { padding: 1.8rem 2rem; flex: 1; }
.pf {
  display: flex; gap: .7rem; align-items: flex-start;
